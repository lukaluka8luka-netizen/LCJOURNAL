      // Weekly Summary
      // Weekly Summary
      function renderWeeklySummary() {
        const year = displayDate.getFullYear();
        const month = displayDate.getMonth();
        const month = displayDate.getMonth();
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const container = document.getElementById("weeklyListContainer");
        if (!container) return;
        container.innerHTML = "";
        container.innerHTML = "";

        const titleEl = document.getElementById("weeklySectionTitle");
        if (titleEl) {
        if (titleEl) {
          titleEl.innerHTML = `<i class="fa-solid fa-chart-bar" style="color: var(--success)"></i> კვირის რეზიუმე (${monthNames[month]} ${year})`;
        }

        const weeks = [
        const weeks = [
          { name: "კვირა 1", start: 1, end: 7, pnl: 0 },
          { name: "კვირა 2", start: 8, end: 14, pnl: 0 },
          { name: "კვირა 3", start: 15, end: 21, pnl: 0 },
          { name: "კვირა 3", start: 15, end: 21, pnl: 0 },
          { name: "კვირა 4", start: 22, end: daysInMonth, pnl: 0 },
        ];

        trades
        trades
          .filter((t) => t.accountId === activeAccountId)
          .forEach((t) => {
            if (!t.date) return;
            if (!t.date) return;
            const parts = t.date.split("-");
            if (parts.length === 3) {
              const tradeYear = parseInt(parts[0], 10);
              const tradeMonth = parseInt(parts[1], 10) - 1; // 0-based
              const tradeMonth = parseInt(parts[1], 10) - 1; // 0-based
              const day = parseInt(parts[2], 10);
              if (tradeYear === year && tradeMonth === month) {
                const amount = parseFloat(t.pnl) || 0;
                const amount = parseFloat(t.pnl) || 0;
                if (day <= 7) weeks[0].pnl += amount;
                else if (day <= 14) weeks[1].pnl += amount;
                else if (day <= 21) weeks[2].pnl += amount;
                else weeks[3].pnl += amount;
                else weeks[3].pnl += amount;
              }
            }
          });
          });

        let maxAbsPnl = Math.max(...weeks.map((w) => Math.abs(w.pnl)));
        if (maxAbsPnl === 0) maxAbsPnl = 1;


        weeks.forEach((w) => {
          let pnlClass = "neutral";
          if (w.pnl > 0) {
          if (w.pnl > 0) {
            pnlClass = "profit";
          } else if (w.pnl < 0) {
            pnlClass = "loss";
          }
          }

          const width = Math.max(5, (Math.abs(w.pnl) / maxAbsPnl) * 100);


          container.innerHTML += `
            <div class="week-item">
              <div class="week-header">
                <span class="week-name">${w.name} (${w.start}-${w.end})</span>
                <span class="week-name">${w.name} (${w.start}-${w.end})</span>
                <span class="week-pnl ${pnlClass} mono-font">${formatCurrency(w.pnl, true)}</span>
              </div>
              <div class="progress-track"><div class="progress-fill ${pnlClass}" style="width: ${w.pnl === 0 ? 0 : width}%"></div></div>
              <div class="progress-track"><div class="progress-fill ${pnlClass}" style="width: ${w.pnl === 0 ? 0 : width}%"></div></div>
            </div>
          `;
        });
      }
      }

