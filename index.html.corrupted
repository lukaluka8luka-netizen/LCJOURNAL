            maintainAspectRatio: false,
            maintainAspectRatio: false,
            animation: {
              x: {
              x: {
                type: "number",
                easing: "easeInOutQuad",
                duration: 800,
                duration: 800,
                from: NaN,
                delay(ctx) {
                delay(ctx) {
                  if (ctx.type !== "data") return 0;
                  const delayVal = dataPoints.length
                  const delayVal = dataPoints.length
                    ? 800 / dataPoints.length
                    : 0;
                  return ctx.dataIndex * delayVal;
                  return ctx.dataIndex * delayVal;
                },
              },
              },
              y: {
                type: "number",
                type: "number",
                easing: "easeInOutQuad",
                duration: 800,
                from: NaN,
                from: NaN,
                delay(ctx) {
                  if (ctx.type !== "data") return 0;
                  if (ctx.type !== "data") return 0;
                  const delayVal = dataPoints.length
                    ? 800 / dataPoints.length
                    ? 800 / dataPoints.length
                    : 0;
                  return ctx.dataIndex * delayVal;
                },
                },
              },
            },
            },
            plugins: {
              legend: { display: false },
              legend: { display: false },
              tooltip: {
                backgroundColor: "#0f0b16",
                titleColor: "#fff",
                titleColor: "#fff",
                bodyColor: "#f3f4f6",
                borderColor: "rgba(168, 85, 247, 0.25)",
                borderColor: "rgba(168, 85, 247, 0.25)",
                borderWidth: 1,
                padding: 12,
                padding: 12,
                cornerRadius: 8,
                displayColors: false,
                callbacks: {
                callbacks: {
                  label: function (context) {
                    return `ბალანსი: ${formatCurrency(context.raw)}`;
                    return `ბალანსი: ${formatCurrency(context.raw)}`;
