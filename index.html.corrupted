/* Stagger delays for stats cards */
.stats-grid .stat-card:nth-child(1) {
animation-delay: 0.03s;
}
.stats-grid .stat-card:nth-child(2) {
animation-delay: 0.06s;
}
.stats-grid .stat-card:nth-child(3) {
animation-delay: 0.09s;
}
.stats-grid .stat-card:nth-child(4) {
animation-delay: 0.12s;
}
.stats-grid .stat-card:nth-child(5) {
animation-delay: 0.15s;
}
.stats-grid .stat-card:nth-child(6) {
animation-delay: 0.18s;
}
.stats-grid .stat-card:nth-child(7) {
animation-delay: 0.21s;
}
.stats-grid .stat-card:nth-child(8) {
animation-delay: 0.24s;
}
.stats-grid .stat-card:nth-child(9) {
animation-delay: 0.27s;
}
.stats-grid .stat-card:nth-child(10) {
animation-delay: 0.3s;
}

.dashboard-container > section,
.dashboard-container > div > section {
animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
}
.dashboard-container > section:nth-of-type(1) {
animation-delay: 0.15s;
}
.dashboard-container > div > section:nth-of-type(1) {
animation-delay: 0.2s;
}
.dashboard-container > div > section:nth-of-type(2) {
animation-delay: 0.25s;
}

/* Improved Modal Spring Zoom Transition */
.modal-overlay {
transition: opacity 0.3s ease;
}
.modal-content {
transform: scale(0.92) translateY(15px);
transition:
transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
opacity 0.3s ease; /* spring easeOutBack */
opacity: 0;
}
.modal-overlay.active .modal-content {
transform: scale(1) translateY(0);
opacity: 1;
}

/* Hover micro-interactions for inputs, select and textarea */
.journal-form input,
.journal-form select,
.journal-form textarea,
.input-group input,
#activeAccountSelect {
flex-direction: column;
padding: 25px 0;
height: 100vh;
position: sticky;
top: 0;
flex-shrink: 0;
z-index: 90;
}
.sidebar-brand {
display: flex;
align-items: center;
gap: 10px;
padding: 0 20px;
margin-bottom: 20px;
}
.sidebar-account-section {
padding: 0 15px;
margin: 10px 0 25px 0;
display: flex;
flex-direction: column;
gap: 8px;
}
.nav-menu {
list-style: none;
display: flex;
flex-direction: column;
gap: 6px;
padding: 0 12px;
}
.nav-item {
padding: 12px 16px;

/* Sidebar & Layout styles */
.dashboard-container {
display: flex;
flex-direction: row;
min-height: 100vh;
width: 100%;
background: transparent;
border: none;
padding: 0;
margin: 0;
border-radius: 0;
box-shadow: none;
}
.sidebar {
width: 260px;
background: rgba(10, 5, 20, 0.6);
backdrop-filter: blur(16px);
border-right: 1px solid var(--border-color);
display: flex;
flex-direction: column;
padding: 25px 0;
height: 100vh;
position: sticky;
top: 0;
flex-shrink: 0;
z-index: 90;
}
.sidebar-brand {
display: flex;
align-items: center;
gap: 3px;
padding: 0 20px;
margin-bottom: 20px;
cursor: pointer;
user-select: none;
transition: opacity 0.2s;
}
.sidebar-brand:hover {
opacity: 0.85;
}
.sidebar-account-section {
padding: 0 15px;
margin: 10px 0 25px 0;
display: flex;
flex-direction: column;
gap: 8px;
}
.nav-menu {
list-style: none;
display: flex;
flex-direction: column;
gap: 6px;
padding: 0 12px;
}
.nav-item {
padding: 12px 16px;
border-radius: 10px;
color: var(--text-muted);
display: flex;
align-items: center;
gap: 12px;
cursor: pointer;
font-weight: 600;
font-size: 13.5px;
transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
border: 1px solid transparent;
}
.nav-item i {
font-size: 15px;
width: 20px;
text-align: center;
}
.nav-item:hover {
color: #fff;
background: rgba(255, 255, 255, 0.03);
}
.nav-item-home:hover {
color: #fff;
background: rgba(255, 255, 255, 0.03);
border-color: rgba(255, 255, 255, 0.08);
}
.nav-item.active {
background: var(--accent-blue);
color: #fff;
box-shadow: 0 4px 20px var(--accent-blue-glow);
}
.nav-item.active i {
color: #fff;
}
.main-content {
flex: 1;
display: flex;
flex-direction: column;
height: 100vh;
overflow-y: auto;
padding: 30px 40px;
box-sizing: border-box;
}
header {
display: flex;
justify-content: space-between;
align-items: center;
margin-bottom: 30px;
padding-top: 10px;
padding-bottom: 15px;
border-bottom: 1px solid var(--border-color);
flex-shrink: 0;
position: sticky;
top: 0;
z-index: 50;
background: rgba(12, 6, 22, 0.95);
backdrop-filter: blur(15px);
margin-top: -30px; /* pull into top padding */
}
body.light-theme header {
background: rgba(243, 244, 246, 0.95) !important;
}
.app-screen-tab {
display: flex !important;
flex-direction: column;
gap: 25px;
min-height: 98vh;
margin-bottom: 220px;
padding-bottom: 120px;
border-bottom: 1px dashed rgba(255, 255, 255, 0.08);
scroll-margin-top: 110px; /* spacing for sticky header */
}
@keyframes tabFadeIn {
from {
opacity: 0;
transform: translateY(12px);
}
to {
opacity: 1;
transform: translateY(0);
}
}

/* Calendar Split Layout */
.calendar-layout {
display: flex;
gap: 25px;
align-items: stretch;
}
.calendar-main-pane {
flex: 1;
min-width: 0;
}
.calendar-side-pane {
width: 320px;
flex-shrink: 0;
background: rgba(18, 11, 28, 0.2);
border: 1px solid var(--border-color);
border-radius: 12px;
padding: 20px;
display: flex;
flex-direction: column;
gap: 15px;
}
.calendar-side-pane h3 {
font-size: 14px;
font-weight: 700;
color: #fff;
margin: 0;
display: flex;
align-items: center;
gap: 8px;
border-bottom: 1px solid var(--border-color);
padding-bottom: 10px;
}
.calendar-side-metric {
background: rgba(0, 0, 0, 0.25);
border: 1px solid var(--border-color);
border-radius: 8px;
padding: 12px;
display: flex;
flex-direction: column;
gap: 4px;
}
.calendar-side-metric span:first-child {
font-size: 11px;
color: var(--text-muted);
text-transform: uppercase;
}
.calendar-side-metric span:last-child {
font-size: 15px;
font-weight: 700;
}
.calendar-notes-box h4 {
font-size: 12px;
font-weight: 700;
color: #fff;
margin-bottom: 8px;
display: flex;
align-items: center;
gap: 6px;
}
.calendar-notes-box textarea {
width: 100%;
height: 120px;
background: rgba(0, 0, 0, 0.3);
border: 1px solid var(--border-color);
border-radius: 8px;
color: #fff;
padding: 10px;
font-size: 13px;
outline: none;
resize: none;
transition: border-color 0.3s;
}
.calendar-notes-box textarea:focus {
border-color: var(--accent-blue);
}

/* Leaderboard components */
.leaderboards-container {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 20px;
}
.leaderboard-column {
display: flex;
flex-direction: column;
gap: 12px;
}
.leaderboard-item {
display: flex;
justify-content: space-between;
align-items: center;
padding: 12px;
background: rgba(255, 255, 255, 0.02);
border: 1px solid var(--border-color);
border-radius: 8px;
font-size: 13px;
}
.leaderboard-item-name {
font-weight: 700;
color: #fff;
}
.leaderboard-item-stats {
font-size: 11px;
color: var(--text-muted);
}
.leaderboard-item-pnl {
font-family: "JetBrains Mono", monospace;
font-weight: 700;
font-size: 12px;
}

/* Achievements tier styling */
.achievement-row {
background: rgba(18, 11, 28, 0.25);
border: 1px solid var(--border-color);
border-radius: 12px;
padding: 20px;
display: flex;
flex-direction: column;
gap: 15px;
}
.achievement-row-title {
font-size: 14px;
font-weight: 700;
color: #fff;
display: flex;
align-items: center;
gap: 8px;
border-bottom: 1px solid var(--border-color);
padding-bottom: 8px;
}
.achievement-tiers-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
gap: 15px;
}
.achievement-card {
padding: 15px;
background: rgba(255, 255, 255, 0.02);
border: 1px solid var(--border-color);
border-radius: 10px;
display: flex;
align-items: center;
gap: 12px;
transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
opacity: 0.45;
position: relative;
}
.achievement-card.unlocked {
opacity: 1;
background: rgba(168, 85, 247, 0.03);
border-color: rgba(168, 85, 247, 0.3);
box-shadow: 0 4px 15px rgba(168, 85, 247, 0.08);
}
.achievement-icon {
font-size: 20px;
color: var(--text-muted);
width: 32px;
height: 32px;
display: flex;
align-items: center;
justify-content: center;
background: rgba(255, 255, 255, 0.03);
border-radius: 8px;
}
.achievement-card.unlocked .achievement-icon {
color: var(--accent-blue);
background: rgba(168, 85, 247, 0.1);
text-shadow: 0 0 10px var(--accent-blue-glow);
}
.achievement-info {
display: flex;
flex-direction: column;
gap: 3px;
min-width: 0;
}
.achievement-name {
font-weight: 700;
font-size: 13px;
color: #fff;
}
.achievement-desc {
font-size: 11px;
color: var(--text-muted);
}
.achievement-status {
position: absolute;
top: 10px;
right: 10px;
font-size: 11px;
}

/* --- Landing Page Styles (Sydview Style) --- */
#landingScreen {
background-color: #0b0713;
background-image:
radial-gradient(
circle at 10% 20%,
rgba(168, 85, 247, 0.08) 0%,
transparent 45%
),
radial-gradient(
circle at 90% 80%,
rgba(14, 165, 233, 0.06) 0%,
transparent 45%
);
color: #f3f4f6;
font-family: "Inter", sans-serif;
height: 100vh;
overflow-y: auto;
overflow-x: hidden;
position: relative;
display: block;
}
.landing-navbar {
display: flex;
justify-content: space-between;
align-items: center;
padding: 20px 8%;
position: sticky;
top: 0;
z-index: 1000;
background: rgba(11, 7, 19, 0.7);
backdrop-filter: blur(12px);
-webkit-backdrop-filter: blur(12px);
border-bottom: 1px solid rgba(255, 255, 255, 0.03);
}
.landing-logo {
display: flex;
align-items: center;
gap: 3px;
font-size: 22px;
font-weight: 900;
background: linear-gradient(135deg, #fff 40%, #a855f7 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
text-decoration: none;
}
.landing-nav-links {
display: flex;
gap: 30px;
}
.landing-nav-links a {
color: var(--text-muted);
text-decoration: none;
font-size: 13.5px;
font-weight: 500;
transition: color 0.3s;
}
.landing-nav-links a:hover {
color: #fff;
}
.landing-nav-actions {
display: flex;
gap: 15px;
align-items: center;
}
.btn-landing-secondary {
background: transparent;
color: #fff;
border: 1px solid rgba(255, 255, 255, 0.15);
padding: 8px 18px;
border-radius: 8px;
font-size: 13px;
font-weight: 700;
cursor: pointer;
transition: all 0.3s;
}
.btn-landing-secondary:hover {
border-color: #fff;
background: rgba(255, 255, 255, 0.03);
}
.btn-landing-primary {
background: linear-gradient(
135deg,
var(--accent-blue) 0%,
#7c3aed 100%
);
color: #fff;
border: none;
padding: 9px 20px;
border-radius: 8px;
font-size: 13px;
font-weight: 700;
cursor: pointer;
transition: all 0.3s;
box-shadow: 0 4px 15px rgba(168, 85, 247, 0.25);
}
.btn-landing-primary:hover {
transform: translateY(-1px);
box-shadow: 0 6px 20px rgba(168, 85, 247, 0.4);
}
.landing-hero {
padding: 100px 8% 80px 8%;
text-align: center;
position: relative;
display: flex;
flex-direction: column;
align-items: center;
}
.landing-hero::before {
content: "";
position: absolute;
width: 300px;
height: 300px;
background: var(--accent-blue-glow);
filter: blur(150px);
top: 20%;
left: 50%;
transform: translate(-50%, -50%);
pointer-events: none;
z-index: 0;
}
.landing-badge {
background: rgba(168, 85, 247, 0.08);
border: 1px solid rgba(168, 85, 247, 0.2);
color: var(--accent-blue);
padding: 6px 14px;
border-radius: 100px;
font-size: 12px;
font-weight: 700;
margin-bottom: 25px;
display: inline-flex;
align-items: center;
gap: 6px;
z-index: 1;
letter-spacing: 0.5px;
}
.landing-title {
font-size: 56px;
font-weight: 900;
line-height: 1.15;
letter-spacing: -1.5px;
max-width: 850px;
margin-bottom: 20px;
background: linear-gradient(135deg, #fff 50%, #9ca3af 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
z-index: 1;
}
.landing-subtitle {
color: var(--text-muted);
font-size: 18px;
max-width: 600px;
line-height: 1.6;
margin-bottom: 35px;
z-index: 1;
}
.landing-hero-btns {
display: flex;
gap: 15px;
z-index: 1;
margin-bottom: 60px;
}
.landing-hero-btns .btn-landing-primary {
padding: 14px 28px;
font-size: 15px;
}
.landing-hero-btns .btn-landing-secondary {
padding: 14px 28px;
font-size: 15px;
}

/* Glowing grid mockup */
.landing-mockup-wrapper {
width: 100%;
max-width: 1000px;
margin: 0 auto;
position: relative;
z-index: 1;
}
.landing-mockup-glow {
position: absolute;
top: 0;
left: 10%;
right: 10%;
bottom: 0;
background: linear-gradient(135deg, #a855f7, #0ea5e9);
filter: blur(80px);
opacity: 0.15;
z-index: 0;
border-radius: 16px;
}
.landing-mockup {
background: rgba(18, 12, 30, 0.4);
border: 1px solid rgba(255, 255, 255, 0.05);
box-shadow: 0 30px 70px rgba(0, 0, 0, 0.7);
border-radius: 16px;
padding: 20px;
backdrop-filter: blur(10px);
-webkit-backdrop-filter: blur(10px);
z-index: 1;
position: relative;
overflow: hidden;
}

/* Feature Grid */
.landing-section {
padding: 80px 8%;
position: relative;
}
