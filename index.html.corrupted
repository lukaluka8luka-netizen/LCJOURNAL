function triggerAiResponse(query) {
const sug = document.getElementById("aiChatSuggestions");
if (sug) sug.style.display = "none";

const q = query.toLowerCase();
let reply = "";

if (
q.includes("add trade") ||
q.includes("record trade") ||
q.includes("how to add")
) {
reply =
"To record a trade, click the purple '**Record Trade**' button in the top right corner of the dashboard header. Fill out the asset pair, strategy, result (Win/Loss/B.E.), risk/reward ratio, and upload a screenshot if you have one, then click '**Save to Cloud**'.";
} else if (
q.includes("winrate") ||
q.includes("win rate") ||
q.includes("ratio")
) {
reply =
"Your win rate is calculated as the number of winning trades divided by your total closed trades. You can check your active win rate inside the top stats grid of the dashboard.";
} else if (q.includes("strategy") || q.includes("setup")) {
reply =
"Organizing setups helps you isolate which trading plan performs best. You can add and view strategies on the **Statistics** page, and filter your journal trades by specific strategies.";
} else if (q.includes("calendar")) {
reply =
"The **Interactive Calendar** color-codes days according to daily performance: Green days are profitable, Red days are losses, and Grey days are neutral (Break Even). Double-clicking any calendar day allows you to add a trade directly on that date!";
        if (
          q.includes("add trade") ||
          q.includes("record trade") ||
          q.includes("how to add")
        ) {
          reply =
            "To record a trade, click the purple '**Record Trade**' button in the top right corner of the dashboard header. Fill out the asset pair, strategy, result (Win/Loss/B.E.), risk/reward ratio, and upload a screenshot if you have one, then click '**Save to Cloud**'.";
        } else if (
          q.includes("winrate") ||
          q.includes("win rate") ||
          q.includes("ratio")
        ) {
          reply =
            "Your win rate is calculated as the number of winning trades divided by your total closed trades. You can check your active win rate inside the top stats grid of the dashboard.";
        } else if (q.includes("strategy") || q.includes("setup")) {
          reply =
            "Organizing setups helps you isolate which trading plan performs best. You can add and view strategies on the **Statistics** page, and filter your journal trades by specific strategies.";
        } else if (q.includes("calendar")) {
          reply =
            "The **Interactive Calendar** color-codes days according to daily performance: Green days are profitable, Red days are losses, and Grey days are neutral (Break Even). Double-clicking any calendar day allows you to add a trade directly on that date!";
        } else if (q.includes("achievements") || q.includes("badge")) {
          reply =
            "You unlock trading badges on the **Achievements** page as you record more trades, hit win-streak milestones, and maintain disciplined execution. Unlocked badges glow in premium purple gradients!";
        } else if (
          q.includes("pnl") ||
          q.includes("profit") ||
          q.includes("loss")
        ) {
          reply =
            "Your Net P&L shows your cumulative net profits minus losses. You can view your daily, weekly, and monthly P&L breakdowns directly on the Dashboard widgets and Calendar summaries.";
        } else if (q.includes("georgian") || q.includes("ქართული")) {
          reply =
            "Georgian language support has been removed as per styling instructions to streamline locales to English (default) and Russian translations.";
        } else if (
          q.includes("hello") ||
          q.includes("hi") ||
          q.includes("hey")
        ) {
          reply =
            "Hello! I am your AI Trading Coach. How can I help you improve your trading consistency and review your journal today?";
        } else {
          reply =
            "That is a great question! Successful trading is 80% psychology and risk management. Always maintain a disciplined Risk-to-Reward ratio (at least 1:2), review your journal daily, and avoid overtrading. Is there a specific chart feature or trading metric you would like me to explain?";
        }

        const typingDiv = document.createElement("div");
        typingDiv.style.display = "flex";
        typingDiv.style.gap = "8px";
        typingDiv.style.alignItems = "center";
        typingDiv.style.maxWidth = "85%";
        typingDiv.id = "aiTypingIndicator";
        typingDiv.innerHTML = `
          <div style="width: 24px; height: 24px; border-radius: 50%; background: rgba(168, 85, 247, 0.15); display: flex; align-items: center; justify-content: center; color: #8b5cf6; font-size: 10px; flex-shrink: 0;"><i class="fa-solid fa-robot"></i></div>
          <div style="font-size: 11px; color: var(--text-muted); font-style: italic;">AI is typing...</div>
        `;
        aiChatMessages.appendChild(typingDiv);
        aiChatMessages.scrollTop = aiChatMessages.scrollHeight;

        setTimeout(() => {
          const indicator = document.getElementById("aiTypingIndicator");
          if (indicator) indicator.remove();
          appendChatMessage("ai", reply);
        }, 1000);
      }

      function handleSendQuery() {
        const text = aiChatInput.value.trim();
        if (!text) return;
        appendChatMessage("user", text);
        aiChatInput.value = "";
        triggerAiResponse(text);
      }

      if (sendAiChatBtn && aiChatInput) {
        sendAiChatBtn.onclick = handleSendQuery;
        aiChatInput.onkeydown = (e) => {
          if (e.key === "Enter") handleSendQuery();
        };
      }

      document.querySelectorAll(".ai-suggest-btn").forEach((btn) => {
        btn.onclick = () => {
          const query = btn.getAttribute("data-query");
          appendChatMessage("user", query);
          triggerAiResponse(query);
        };
      });





































































