// Set default language state
let currentLang = localStorage.getItem("lctrading_lang") || "en";
if (currentLang === "ka" || !locales[currentLang]) {
currentLang = "en";
localStorage.setItem("lctrading_lang", "en");
}

function translatePage(lang) {
if (!lang || !locales[lang]) lang = "en";
currentLang = lang;
localStorage.setItem("lctrading_lang", lang);
window.currentLang = lang;

const dict = locales[lang] || locales.en;
if (!dict) return;

// Translate static elements with data-i18n
document.querySelectorAll("[data-i18n]").forEach((el) => {
const key = el.getAttribute("data-i18n");
if (dict[key]) {
if (el.hasAttribute("placeholder")) {
el.setAttribute("placeholder", dict[key]);
} else {
el.innerHTML = dict[key];
}
}
});

// Set select values
const select = document.getElementById("langSelect");
if (select) select.value = lang;
const selectSidebar = document.getElementById("langSelectSidebar");
if (selectSidebar) selectSidebar.value = lang;

// Sync dynamic landing buttons
if (typeof updateLandingUI === "function") {
updateLandingUI(auth.currentUser);
}

// Render dashboard widgets or active views to sync names if dashboard is open
if (document.getElementById("appScreen").style.display !== "none") {
if (typeof renderDashboard === "function") renderDashboard();
if (typeof renderCalendar === "function") renderCalendar();
if (typeof renderDetailedStats === "function") renderDetailedStats();

// Update header title/subtitle based on current active tab
const activeNav = document.querySelector(".nav-item.active");
