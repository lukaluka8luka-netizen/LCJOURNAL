activeAccountId = newDoc.id;
localStorage.setItem(
"activeAccountId_" + user.uid,
activeAccountId,
);

addAccountModal.classList.remove("active");
} catch (err) {
alert("შეცდომა ანგარიშის შექმნისას: " + err.message);
} finally {
saveBtn.disabled = false;
saveBtn.textContent = "ანგარიშის შექმნა";
}
});
</script>
