function updateStats() {
const activeTrades = trades.filter(
(t) => t.accountId === activeAccountId,
);

const statWinRateEl = document.getElementById("statWinRate");
const statTotalPnLEl = document.getElementById("statTotalPnL");
const statAvgWinEl = document.getElementById("statAvgWin");
const statAvgLossEl = document.getElementById("statAvgLoss");
const statProfitFactorEl = document.getElementById("statProfitFactor");
const statStreakEl = document.getElementById("statStreak");
const statBestAssetEl = document.getElementById("statBestAsset");
const statBestStrategyEl = document.getElementById("statBestStrategy");
const statMaxWinEl = document.getElementById("statMaxWin");

const statWinLossCountEl = document.getElementById("statWinLossCount");
const statWinCountLabelEl =
document.getElementById("statWinCountLabel");
const statLossCountLabelEl =
document.getElementById("statLossCountLabel");
const pbarWinEl = document.getElementById("pbarWin");
const pbarLossEl = document.getElementById("pbarLoss");

if (activeTrades.length === 0) {
if (statWinRateEl) statWinRateEl.textContent = "0%";
if (statTotalPnLEl) {
statTotalPnLEl.textContent = formatCurrency(0);
statTotalPnLEl.className = "card-value mono-font gray";
}
if (statAvgWinEl) statAvgWinEl.textContent = formatCurrency(0);
if (statAvgLossEl) statAvgLossEl.textContent = formatCurrency(0);
if (statProfitFactorEl) statProfitFactorEl.textContent = "0.00";
if (statStreakEl) {
statStreakEl.innerHTML = "0 -";
statStreakEl.style.color = "var(--text-muted)";
}
if (statBestAssetEl) statBestAssetEl.textContent = "-";
if (statBestStrategyEl) statBestStrategyEl.textContent = "-";
if (statMaxWinEl) statMaxWinEl.textContent = formatCurrency(0);

if (statWinLossCountEl) statWinLossCountEl.textContent = "0";
if (statWinCountLabelEl) statWinCountLabelEl.textContent = "0 W (0%)";
if (statLossCountLabelEl)
statLossCountLabelEl.textContent = "0 L (0%)";
if (pbarWinEl) pbarWinEl.style.width = "0%";
if (pbarLossEl) pbarLossEl.style.width = "0%";
return;
}

let wins = 0,
losses = 0,
grossProfit = 0,
grossLoss = 0,
totalPnl = 0,
maxWin = 0;

const assetStats = {};
const strategyStats = {};

activeTrades.forEach((t) => {
const amount = parseFloat(t.pnl);
totalPnl += amount;

// Asset and Strategy stats
const pair = (t.pair || "").toUpperCase().trim();
const strat = (t.strategy || "").trim();
if (pair) {
assetStats[pair] = (assetStats[pair] || 0) + amount;
}
if (strat) {
strategyStats[strat] = (strategyStats[strat] || 0) + amount;
}

if (amount > 0) {
wins++;
grossProfit += amount;
if (amount > maxWin) {
maxWin = amount;
}
} else if (amount < 0) {
losses++;
grossLoss += Math.abs(amount);
}
});

const totalFinished = wins + losses;
const winRate =
totalFinished > 0 ? ((wins / totalFinished) * 100).toFixed(1) : 0;

if (statWinRateEl) {
statWinRateEl.textContent = `${winRate}%`;
statWinRateEl.className = `card-value mono-font ${winRate >= 50 ? "green" : "red"}`;
}

if (statTotalPnLEl) {
statTotalPnLEl.textContent = formatCurrency(totalPnl, true);
statTotalPnLEl.className = `card-value mono-font ${totalPnl > 0 ? "green" : totalPnl < 0 ? "red" : "gray"}`;
}

const avgWin = wins > 0 ? grossProfit / wins : 0;
const avgLoss = losses > 0 ? grossLoss / losses : 0;
if (statAvgWinEl)
statAvgWinEl.textContent = formatCurrency(avgWin, true);
if (statAvgLossEl)
statAvgLossEl.textContent = formatCurrency(-avgLoss, false);

const pf =
grossLoss > 0
? (grossProfit / grossLoss).toFixed(2)
: grossProfit > 0
? "MAX"
: "0.00";
if (statProfitFactorEl) statProfitFactorEl.textContent = pf;

let currentStreak = 0,
streakType = null;
const sortedTrades = [...activeTrades].sort(
(a, b) => b.timestamp - a.timestamp,
);
for (let t of sortedTrades) {
const amount = parseFloat(t.pnl);
if (amount === 0) continue;
const type = amount > 0 ? "W" : "L";
if (streakType === null) {
streakType = type;
currentStreak++;
} else if (streakType === type) {
currentStreak++;
} else {
break;
}
}

if (statStreakEl) {
if (currentStreak === 0) {
statStreakEl.innerHTML = `0 -`;
statStreakEl.style.color = "var(--text-muted)";
} else if (streakType === "W") {
const winStr =
currentLang === "ka"
? "მოგება"
: currentLang === "ru"
? "Выигрыш"
: "Win";
statStreakEl.innerHTML = `${currentStreak} ${winStr} 🔥`;
statStreakEl.style.color = "var(--success)";
} else {
const lossStr =
currentLang === "ka"
? "წაგება"
: currentLang === "ru"
? "Проигрыш"
: "Loss";
statStreakEl.innerHTML = `${currentStreak} ${lossStr} ❄️`;
statStreakEl.style.color = "var(--danger)";
}
}

// Best asset
let bestAsset = "-";
let maxAssetPnl = -Infinity;
for (const asset in assetStats) {
if (assetStats[asset] > maxAssetPnl && assetStats[asset] > 0) {
maxAssetPnl = assetStats[asset];
bestAsset = asset;
}
}
if (statBestAssetEl) {
        if (statBestAssetEl) {
          statBestAssetEl.textContent =
            bestAsset !== "-"
            bestAsset !== "-"
              ? `${bestAsset} (${formatCurrency(maxAssetPnl, true)})`
              : "-";
              : "-";
        }

        // Best strategy
        // Best strategy
        let bestStrategy = "-";
        let maxStratPnl = -Infinity;
        let maxStratPnl = -Infinity;
        for (const strat in strategyStats) {
          if (strategyStats[strat] > maxStratPnl && strategyStats[strat] > 0) {
          if (strategyStats[strat] > maxStratPnl && strategyStats[strat] > 0) {
            maxStratPnl = strategyStats[strat];
            bestStrategy = strat;
          }
          }
        }
        if (statBestStrategyEl) {
        if (statBestStrategyEl) {
          statBestStrategyEl.textContent =
            bestStrategy !== "-"
            bestStrategy !== "-"
              ? `${bestStrategy} (${formatCurrency(maxStratPnl, true)})`
              : "-";
        }
        }

        // Total trades count and max win
        // Total trades count and max win
        if (statWinLossCountEl) {
          statWinLossCountEl.textContent = activeTrades.length;
          statWinLossCountEl.textContent = activeTrades.length;
        }

        const winPercent =
        const winPercent =
          activeTrades.length > 0
            ? ((wins / activeTrades.length) * 100).toFixed(0)
            ? ((wins / activeTrades.length) * 100).toFixed(0)
            : 0;
        const lossPercent =
        const lossPercent =
          activeTrades.length > 0
            ? ((losses / activeTrades.length) * 100).toFixed(0)
            : 0;
            : 0;

        if (statWinCountLabelEl)
        if (statWinCountLabelEl)
          statWinCountLabelEl.textContent = `${wins} W (${winPercent}%)`;
        if (statLossCountLabelEl)
        if (statLossCountLabelEl)
          statLossCountLabelEl.textContent = `${losses} L (${lossPercent}%)`;

        if (pbarWinEl) pbarWinEl.style.width = `${winPercent}%`;
        if (pbarWinEl) pbarWinEl.style.width = `${winPercent}%`;
        if (pbarLossEl) pbarLossEl.style.width = `${lossPercent}%`;


        if (statMaxWinEl)
          statMaxWinEl.textContent = formatCurrency(maxWin, true);
          statMaxWinEl.textContent = formatCurrency(maxWin, true);
      }

      // გრაფიკის ფილტრები
