                ticks: { color: "#8b809a" },
                ticks: { color: "#8b809a" },
              },
            },
            },
          },
        };
        };
      }

      function renderChart() {
      function renderChart() {
        const accountTrades = trades.filter(
          (t) => t.accountId === activeAccountId,
          (t) => t.accountId === activeAccountId,
        );
        let chronologicalTrades = [...accountTrades].sort(
        let chronologicalTrades = [...accountTrades].sort(
          (a, b) => a.timestamp - b.timestamp,
        );


        const now = new Date().getTime();
        let filteredTrades = chronologicalTrades;
        let filteredTrades = chronologicalTrades;

        if (currentChartFilter === "year") {
        if (currentChartFilter === "year") {
          const oneYearAgo = now - 365 * 24 * 60 * 60 * 1000;
          filteredTrades = chronologicalTrades.filter(
            (t) => t.timestamp >= oneYearAgo,
            (t) => t.timestamp >= oneYearAgo,
          );
        } else if (currentChartFilter === "month") {
        } else if (currentChartFilter === "month") {
          const oneMonthAgo = now - 30 * 24 * 60 * 60 * 1000;
          filteredTrades = chronologicalTrades.filter(
          filteredTrades = chronologicalTrades.filter(
            (t) => t.timestamp >= oneMonthAgo,
          );
        } else if (currentChartFilter === "week") {
        } else if (currentChartFilter === "week") {
          const oneWeekAgo = now - 7 * 24 * 60 * 60 * 1000;
          filteredTrades = chronologicalTrades.filter(
          filteredTrades = chronologicalTrades.filter(
            (t) => t.timestamp >= oneWeekAgo,
          );
          );
        }

        const activeAcc = accounts.find((a) => a.id === activeAccountId);
        const activeAcc = accounts.find((a) => a.id === activeAccountId);
        const startingBalance = activeAcc
          ? parseFloat(activeAcc.startingBalance)
          ? parseFloat(activeAcc.startingBalance)
          : 50000;
        let currentBalance = startingBalance;
        let currentBalance = startingBalance;
        const dataPoints = [startingBalance];
        const labels = ["სტარტი"];


        filteredTrades.forEach((t) => {
          currentBalance += parseFloat(t.pnl);
          currentBalance += parseFloat(t.pnl);
          dataPoints.push(currentBalance);
          labels.push(t.date);
          labels.push(t.date);
