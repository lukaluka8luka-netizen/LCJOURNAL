        ) {
          const ctx = canvasDashboard.getContext("2d");
          if (equityChartInstance) equityChartInstance.destroy();
          if (equityChartInstance) equityChartInstance.destroy();
          equityChartInstance = new Chart(
            ctx,
            ctx,
            createChartConfig(ctx, labels, dataPoints),
          );
}

function renderTable() {
const container = document.getElementById("journalDayGroups");
if (!container) return;
container.innerHTML = "";

const dbg = document.getElementById("journalDebugDiv");
if (dbg) {
dbg.style.display = "none";
dbg.innerHTML = "";
}

try {
updateJournalMonthDisplay();

const searchEl = document.getElementById("tableSearch");
const searchQuery = searchEl
? searchEl.value.toLowerCase().trim()
: "";
const filterEl = document.getElementById("tableFilterResult");
const resultFilter = filterEl ? filterEl.value : "all";

let filteredTrades = trades.filter(
(t) => t.accountId === activeAccountId,
);

// Filter by selected Journal Month/Year
filteredTrades = filteredTrades.filter((t) => {
if (!t.date) return false;
const tDate = new Date(t.date + "T12:00:00");
return (
tDate.getMonth() === journalCurrentDate.getMonth() &&
tDate.getFullYear() === journalCurrentDate.getFullYear()
);
});

if (searchQuery) {
filteredTrades = filteredTrades.filter(
(t) =>
(t.pair || "").toLowerCase().includes(searchQuery) ||
(t.strategy || "").toLowerCase().includes(searchQuery),
);
}

if (resultFilter !== "all") {
filteredTrades = filteredTrades.filter(
(t) => t.result === resultFilter,
);
}

const emptyMsgEl = document.getElementById("emptyTableMsg");
if (filteredTrades.length === 0) {
const hasAnyTradesForAccount = trades.some(
(t) => t.accountId === activeAccountId,
);
let extraTip = "";
if (hasAnyTradesForAccount) {
const monthsWithTrades = [];
const monthsNamesList =
currentLang === "ru"
? [
"Январь",
"Февраль",
"Март",
"Апрель",
"Май",
"Июнь",
"Июль",
"Август",
"Сентябрь",
"Октябрь",
"Ноябрь",
"Декабрь",
]
: [
"January",
"February",
"March",
"April",
"May",
"June",
"July",
"August",
"September",
"October",
"November",
"December",
];

trades
.filter((t) => t.accountId === activeAccountId && t.date)
.forEach((t) => {
const tDate = new Date(t.date + "T12:00:00");
const mName = monthsNamesList[tDate.getMonth()];
const yVal = tDate.getFullYear();
const str = `${mName} ${yVal}`;
if (!monthsWithTrades.includes(str)) {
monthsWithTrades.push(str);
}
});

if (monthsWithTrades.length > 0) {
const tipLabel =
currentLang === "ru"
? "У вас есть сделки в других месяцах: "
: "You have trades in other months: ";
extraTip = `<div style="font-size: 11px; color: #a855f7; margin-top: 10px; font-weight: 600; text-shadow: 0 0 10px rgba(168,85,247,0.2);">💡 ${tipLabel} ${monthsWithTrades.join(", ")}</div>`;
}
}

const emptyMsgTrans = {
ka: "ჟურნალი ცარიელია. დაამატეთ თქვენი პირველი თრეიდი!",
en: "Journal is empty. Add your first trade!",
ru: "Журнал пуст. Добавьте свою первую сделку!",
};
const baseMsg = emptyMsgTrans[currentLang] || emptyMsgTrans.en;

if (emptyMsgEl) {
emptyMsgEl.innerHTML = `
<div style="font-size: 13px; color: var(--text-muted); font-weight: 600;">${baseMsg}</div>
${extraTip}
`;
emptyMsgEl.style.display = "block";
}
return;
}

if (emptyMsgEl) emptyMsgEl.style.display = "none";

// Sort newest first
filteredTrades.sort((a, b) => getTradeChronologicalTime(b) - getTradeChronologicalTime(a));

// Group by Date
const grouped = {};
filteredTrades.forEach((t) => {
const date = t.date || "No Date";
if (!grouped[date]) grouped[date] = [];
grouped[date].push(t);
});

const datesSorted = Object.keys(grouped).sort((a, b) =>
b.localeCompare(a),
);

const langObj = locales[currentLang] || locales.en;
const detailLbl = langObj.btn_details || "Details";
const editLbl = langObj.btn_edit || "Edit";
const delLbl = langObj.btn_delete || "Delete";
const expandLbl = langObj.btn_expand || "Expand";
const collapseLbl = langObj.btn_collapse || "Collapse";
const addNoteLbl = langObj.btn_add_note || "Add note";
const updateNoteLbl = langObj.btn_update_note || "Update note";

datesSorted.forEach((dateKey, index) => {
const dayTrades = grouped[dateKey];

// Calculate Stats
let netPnl = 0;
let grossProfit = 0;
let grossLoss = 0;
let winsCount = 0;
let lossesCount = 0;

dayTrades.forEach((t) => {
const val = parseFloat(t.pnl) || 0;
netPnl += val;
if (val > 0) {
grossProfit += val;
winsCount++;
} else if (val < 0) {
grossLoss += Math.abs(val);
lossesCount++;
}
});

const totalTrades = dayTrades.length;
const winrate =
totalTrades > 0 ? Math.round((winsCount / totalTrades) * 100) : 0;
const profitFactor =
grossLoss > 0
? (grossProfit / grossLoss).toFixed(2)
: grossProfit > 0
? "MAX"
: "0.00";
const mockVolume = totalTrades;
const mockCommissions = (totalTrades * 0.78).toFixed(2);

const pnlColorClass =
netPnl > 0 ? "green" : netPnl < 0 ? "red" : "gray";
const grossPnlColorClass = grossProfit > 0 ? "green" : "gray";
const formattedPnl = formatCurrency(netPnl, true);
const formattedGrossPnl = formatCurrency(grossProfit, true);
const formattedCommissions = `$${mockCommissions}`;

// Format Date Header like "17 Jun 2026, Wednesday"
let dateLabel = dateKey;
try {
const d = new Date(dateKey + "T12:00:00");
const dayNames =
currentLang === "ru"
? [
"Воскресенье",
"Понедельник",
"Вторник",
"Среда",
"Четверг",
"Пятница",
"Суббота",
]
: [
"Sunday",
"Monday",
"Tuesday",
"Wednesday",
"Thursday",
"Friday",
"Saturday",
];
const options = {
day: "numeric",
month: "short",
year: "numeric",
};
const dateStr = d.toLocaleDateString(
currentLang === "ru" ? "ru-RU" : "en-US",
options,
);
dateLabel = `${dateStr}, ${dayNames[d.getDay()]}`;
} catch (e) {}

const sparkline = generateSparkline(dayTrades);
let sparklineSvg = "";
if (sparkline) {
const strokeColor = netPnl > 0 ? "#10b981" : "#ef4444";
sparklineSvg = `
<svg class="sparkline" width="60" height="24" viewBox="0 0 60 24" style="overflow: visible; margin-left: 10px;">
<path d="${sparkline}" fill="none" stroke="${strokeColor}" stroke-width="2" stroke-linecap="round" />
</svg>
`;
}

// Fetch Day Note from Cache
const dayNoteText = dailyNotesCache[dateKey] || "";
const noteBtnText = dayNoteText ? updateNoteLbl : addNoteLbl;

const isExpanded = index === 0 || allExpanded;
const groupId = `day-group-${dateKey.replace(/-/g, "")}`;

const dayCard = document.createElement("div");
dayCard.className = "journal-day-group";
dayCard.innerHTML = `
<div class="journal-day-header" onclick="window.toggleDayGroup('${groupId}')">
<div class="jdh-left">
<div class="jdh-date">${dateLabel}</div>
</div>
<div style="display: flex; gap: 8px;" onclick="event.stopPropagation()">
<button class="btn-day-note" onclick="window.openDayNoteModal('${dateKey}')">${noteBtnText}</button>
<button class="jdh-toggle-btn" id="btn-${groupId}" onclick="window.toggleDayGroup('${groupId}')">
<span>${isExpanded ? collapseLbl : expandLbl}</span>
<i class="fa-solid fa-chevron-${isExpanded ? "up" : "down"}"></i>
</button>
</div>

<!-- Stats Row -->
<div class="jdh-stats">
<div class="jdh-stat-group" style="align-items: center;">
<div class="jdh-stat-item">
<span class="jdh-label" data-i18n="stats_net_pnl">Net P&L</span>
<span class="jdh-val pnl-val ${pnlColorClass}">${formattedPnl}</span>
</div>
${sparklineSvg}
</div>
<div class="jdh-divider"></div>

<div class="jdh-stat-group">
<div class="jdh-stat-item">
<span class="jdh-label" data-i18n="stats_total_trades">Total Trades</span>
<span class="jdh-val">${totalTrades}</span>
</div>
<div class="jdh-stat-item">
<span class="jdh-label" data-i18n="mock_winrate">Winrate</span>
<span class="jdh-val">${winrate}%</span>
</div>
</div>
<div class="jdh-divider"></div>

<div class="jdh-stat-group">
<div class="jdh-stat-item">
<span class="jdh-label" data-i18n="stats_gross_pnl">Gross P&L</span>
<span class="jdh-val ${grossPnlColorClass}">${formattedGrossPnl}</span>
</div>
<div class="jdh-stat-item">
<span class="jdh-label" data-i18n="stats_volume">Volume</span>
<span class="jdh-val">${mockVolume}</span>
</div>
</div>
<div class="jdh-divider"></div>

<div class="jdh-stat-group">
<div class="jdh-stat-item">
<span class="jdh-label" data-i18n="stats_commissions">Commissions</span>
<span class="jdh-val">${formattedCommissions}</span>
</div>
</div>
<div class="jdh-divider"></div>

<div class="jdh-stat-group">
<div class="jdh-stat-item">
<span class="jdh-label" data-i18n="stats_winners">Winners</span>
<span class="jdh-val green">${winsCount}</span>
</div>
<div class="jdh-stat-item">
<span class="jdh-label" data-i18n="stats_losers">Losers</span>
<span class="jdh-val red">${lossesCount}</span>
</div>
<div class="jdh-stat-item">
<span class="jdh-label" data-i18n="mock_factor">Profit Factor</span>
<span class="jdh-val">${profitFactor}</span>
</div>
</div>
</div>
</div>

<!-- Trade Rows collapsible block -->
<div class="journal-day-trades ${isExpanded ? "open" : ""}" id="${groupId}" style="display: flex; flex-direction: column;">
${dayTrades
.map((trade) => {
const trAmt = parseFloat(trade.pnl) || 0;
const trPnlColor =
trAmt > 0 ? "green" : trAmt < 0 ? "red" : "gray";
const trBadgeClass =
trAmt > 0 ? "win" : trAmt < 0 ? "loss" : "neutral";

const trResultText =
trAmt > 0
? currentLang === "ru"
? "Выигрыш"
: "Win"
: trAmt < 0
? currentLang === "ru"
? "Проигрыш"
: "Loss"
: "B.E.";

const largePhotoHtml = trade.image
? `<img src="${trade.image}" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" onclick="window.openViewModal('${trade.id}')" />`
: `<div style="display: flex; flex-direction: column; align-items: center; gap: 8px; color: var(--text-muted);"><i class="fa-regular fa-image" style="font-size: 24px;"></i><span style="font-size: 10px; font-weight: 600;">No Screenshot</span></div>`;

return `
<div class="journal-trade-row-card" onclick="window.openViewModal('${trade.id}')" style="display: flex; gap: 20px; padding: 18px; border-bottom: 1px solid var(--border-color); cursor: pointer; transition: background 0.2s;">
<!-- Left Side: Large Screenshot -->
<div class="jtr-image-wrapper" style="width: 240px; height: 135px; border-radius: 8px; overflow: hidden; background: rgba(0,0,0,0.25); border: 1px solid var(--border-color); display: flex; align-items: center; justify-content: center; flex-shrink: 0; position: relative;">
${largePhotoHtml}
</div>

<!-- Right Side: Details Grid -->
<div style="flex: 1; display: flex; flex-direction: column; justify-content: space-between; overflow: hidden;">
<div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 10px;">
<div>
<div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
<span style="font-size: 16px; font-weight: 800; color: #fff;">${(trade.pair || "").toUpperCase()}</span>
<span class="badge ${trBadgeClass}" style="font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 5px;">${trResultText}</span>
</div>
<div style="font-size: 12px; color: var(--text-muted); font-weight: 500; display: flex; flex-wrap: wrap; gap: 15px;">
<span><i class="fa-solid fa-layer-group" style="color: var(--accent-blue); margin-right: 4px;"></i>${trade.strategy || "—"}</span>
<span><i class="fa-solid fa-clock" style="color: var(--accent-blue); margin-right: 4px;"></i>${trade.entryTime || "00:00"} - ${trade.exitTime || "00:00"} (${trade.session || "—"})</span>
</div>
</div>
<div class="jtr-pnl ${trPnlColor}" style="font-size: 20px; font-weight: 800; flex-shrink: 0;">
${formatCurrency(trAmt, true)}
</div>
</div>

<!-- Notes snippet -->
<div style="font-size: 12px; color: var(--text-muted); line-height: 1.5; margin-top: 8px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
${trade.notes || "No notes written for this trade."}
</div>

<!-- Footer details & Actions -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px; padding-top: 10px; border-top: 1px dashed rgba(255,255,255,0.03);">
<div style="font-size: 11.5px; color: var(--text-muted); font-weight: 600;">
<span>🛡️ R/R Ratio: <strong style="color: #fff;">${trade.rrRatio ? `1:${trade.rrRatio}` : "—"}</strong></span>
</div>
<div style="display: flex; gap: 6px;" onclick="event.stopPropagation()">
<button class="btn-view-note" onclick="window.openViewModal('${trade.id}')" title="${detailLbl}" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); color: #fff; width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s;"><i class="fa-regular fa-file-lines" style="font-size: 11px;"></i></button>
<button class="btn-view-note" onclick="window.openEditModal('${trade.id}')" title="${editLbl}" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); color: var(--accent-blue); width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s;"><i class="fa-regular fa-pen-to-square" style="font-size: 11px;"></i></button>
<button class="btn-delete-trade" onclick="window.deleteTrade('${trade.id}')" title="${delLbl}" style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); color: #ef4444; width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s;"><i class="fa-solid fa-trash-can" style="font-size: 11px;"></i></button>
</div>
</div>
</div>
</div>
`;
})
.join("")}
</div>
`;
container.appendChild(dayCard);
});
} catch (err) {
const dbg = document.getElementById("journalDebugDiv");
if (dbg) {
dbg.style.display = "block";
dbg.innerHTML = `⚠️ Render Error: ${err.message}\nStack: ${err.stack}`;
}
console.error("renderTable error:", err);
}
}
function renderCalendar() {
const year = displayDate.getFullYear();
const month = displayDate.getMonth();
const labelEl = document.getElementById("calendarMonthLabel");
if (labelEl) {
const currentMonths = monthNamesAll[currentLang] || monthNamesAll.en;
labelEl.textContent = `${currentMonths[month]} ${year}`;
}

const firstDayIndex = new Date(year, month, 1).getDay();
const startDay = firstDayIndex === 0 ? 6 : firstDayIndex - 1;
