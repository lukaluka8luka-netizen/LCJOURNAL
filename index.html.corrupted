<!-- Header and Filters Row -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px; flex-wrap: wrap; gap: 15px;">
<div>
<h2 style="font-size: 24px; font-weight: 800; color: #fff; margin: 0; font-family: 'Outfit', sans-serif;" data-i18n="stats_title">Statistics</h2>
<p style="font-size: 13px; color: var(--text-muted); margin: 3px 0 0 0;" data-i18n="stats_subtitle">Comprehensive trading performance analytics</p>
</div>

<div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
<select id="statsFilterStrategy" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); color: #fff; padding: 8px 14px; border-radius: 8px; font-size: 12px; font-weight: 600; cursor: pointer; outline: none; transition: border-color 0.2s;" onchange="renderDetailedStats()">
<option value="all">All Strategies</option>
</select>

<select id="statsFilterPeriod" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); color: #fff; padding: 8px 14px; border-radius: 8px; font-size: 12px; font-weight: 600; cursor: pointer; outline: none; transition: border-color 0.2s;" onchange="renderDetailedStats()">
<option value="all">All Time</option>
<option value="30">30 days</option>
<option value="7">7 days</option>
</select>

<button onclick="renderDetailedStats()" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: #fff; padding: 8px 16px; border-radius: 8px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; gap: 6px;" onmouseover="this.style.background='rgba(255,255,255,0.08)'" onmouseout="this.style.background='rgba(255,255,255,0.04)'">
<i class="fa-solid fa-arrows-rotate"></i>
<span data-i18n="stats_btn_refresh">Refresh</span>
</button>
</div>
</div>

<!-- SECTION 1: Performance Overview -->
<section class="glass-panel" style="padding: 25px;">
<h3 style="font-size: 14px; font-weight: 700; color: #fff; text-transform: uppercase; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; letter-spacing: 0.05em;">
<i class="fa-solid fa-chart-line" style="color: var(--accent-blue)"></i>
<span data-i18n="stats_perf_overview">Performance Overview</span>
</h3>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px;">

<!-- Total P&L -->
