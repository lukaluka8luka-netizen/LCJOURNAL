document
.getElementById("toggleAuthMode")
.addEventListener("click", () => {
isLoginMode = !isLoginMode;
const dict = locales[currentLang] || {};
document.getElementById("authTitle").textContent = isLoginMode
? dict.auth_login_title || "სისტემაში შესვლა"
: dict.auth_register_title || "რეგისტრაცია";
document.getElementById("authSubmitBtn").textContent = isLoginMode
? dict.btn_login || "შესვლა"
: dict.btn_register || "რეგისტრაცია";
document.getElementById("toggleAuthMode").textContent = isLoginMode
? dict.auth_no_account || "არ გაქვს ექაუნთი? დარეგისტრირდი"
: dict.auth_have_account || "უკვე გაქვს ექაუნთი? შესვლა";
document.getElementById("nameGroup").style.display = isLoginMode
? "none"
: "flex";
document.getElementById("authName").required = !isLoginMode;
});

document
.getElementById("authForm")
.addEventListener("submit", async (e) => {
e.preventDefault();
const email = document.getElementById("authEmail").value;
const password = document.getElementById("authPassword").value;
const nickname = document.getElementById("authName").value;
const submitBtn = document.getElementById("authSubmitBtn");
const errorMsg = document.getElementById("authErrorMsg");

submitBtn.textContent =
(locales[currentLang] || locales.en).auth_loading ||
"მიმდინარეობს...";
errorMsg.style.display = "none";

try {
if (isLoginMode) {
await signInWithEmailAndPassword(auth, email, password);
} else {
const cred = await createUserWithEmailAndPassword(
auth,
email,
password,
);
await updateProfile(cred.user, { displayName: nickname });
document.getElementById("displayNameDisplay").textContent =
nickname;
if (document.getElementById("profileDropdownName")) {
document.getElementById("profileDropdownName").textContent =
nickname;
}
}
e.target.reset();
} catch (error) {
errorMsg.style.display = "block";
errorMsg.textContent = `❌ შეცდომა: ${error.message}`;
} finally {
submitBtn.textContent = isLoginMode ? "შესვლა" : "რეგისტრაცია";
}
});

// Profile Dropdown Toggle Logic
const profileMenuTrigger = document.getElementById("profileMenuTrigger");
const profileDropdownMenu = document.getElementById(
"profileDropdownMenu",
);

if (profileMenuTrigger && profileDropdownMenu) {
profileMenuTrigger.onclick = (e) => {
e.stopPropagation();
const isOpen = profileDropdownMenu.style.display === "block";
if (isOpen) {
profileDropdownMenu.style.opacity = "0";
profileDropdownMenu.style.transform = "translateY(-10px)";
];
];
];
];






















