            .querySelectorAll(".tag-btn")
            .forEach((b) => b.classList.remove("active"));
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          const tag = btn.getAttribute("data-tag");
          const tableSearch = document.getElementById("tableSearch");
          const tableSearch = document.getElementById("tableSearch");
          if (tag === "ALL") {
            tableSearch.value = "";
          } else {
            tableSearch.value = tag;
            tableSearch.value = tag;
          }
          renderTable();
        };
        };
      });

      // Detailed Statistics page leaderboards group and render
function renderDetailedStats() {
const activeTrades = trades.filter(
(t) => t.accountId === activeAccountId,
);

// Get filters from HTML elements
const stratSelect = document.getElementById("statsFilterStrategy");
const periodSelect = document.getElementById("statsFilterPeriod");

const strategyFilter = stratSelect ? stratSelect.value : "all";
const periodFilter = periodSelect ? periodSelect.value : "all";

const nowMs = new Date().getTime();
let filteredTrades = activeTrades;

if (strategyFilter !== "all") {
filteredTrades = filteredTrades.filter(t => t.strategy === strategyFilter);
}

if (periodFilter !== "all") {
const daysLimit = parseInt(periodFilter, 10);
const limitMs = daysLimit * 24 * 60 * 60 * 1000;
filteredTrades = filteredTrades.filter(t => {
const tTime = getTradeChronologicalTime(t);
return (nowMs - tTime) <= limitMs;
});
}

// 1. Calculate Core Stats
let netPnl = 0;
let winsCount = 0;
let lossesCount = 0;
let grossProfit = 0;
let grossLoss = 0;
let bestTradeVal = 0;
let bestTradeAsset = "—";
let smallestWinVal = Infinity;
let smallestWinAsset = "—";

// Grouping for Best Performance calculations
const dailyPnL = {}; // "YYYY-MM-DD" -> pnl
const weeklyPnL = {}; // "YYYY-WW" -> { pnl, label, count }
const monthlyPnL = {}; // "YYYY-MM" -> { pnl, label, count }
const yearlyPnL = {}; // "YYYY" -> { pnl, label, count }
const sessionPnL = {
"Morning (6AM-12PM)": 0,
"Afternoon (12PM-6PM)": 0,
"Evening (6PM-12AM)": 0,
"Night (12AM-6AM)": 0
};
const sessionCounts = {
"Morning (6AM-12PM)": 0,
"Afternoon (12PM-6PM)": 0,
"Evening (6PM-12AM)": 0,
"Night (12AM-6AM)": 0
};

filteredTrades.forEach((t) => {
const val = parseFloat(t.pnl) || 0;
netPnl += val;

if (val > 0) {
winsCount++;
grossProfit += val;
if (val > bestTradeVal) {
bestTradeVal = val;
bestTradeAsset = t.pair || "—";
}
if (val < smallestWinVal) {
smallestWinVal = val;
smallestWinAsset = t.pair || "—";
}
} else if (val < 0) {
lossesCount++;
grossLoss += Math.abs(val);
}

// Best Day grouping
if (t.date) {
dailyPnL[t.date] = (dailyPnL[t.date] || 0) + val;

// Best Month grouping
const mParts = t.date.split("-");
if (mParts.length >= 2) {
const yearVal = mParts[0];
const monthVal = parseInt(mParts[1], 10) - 1;
const ymKey = `${yearVal}-${mParts[1]}`;
const mNameList =
currentLang === "ru"
? [
"Январь", "Февраль", "Март", "Апрель", "Май", "Июнь",
"Июль", "Август", "Сентябрь", "Октябрь", "Ноябрь", "Декабрь"
]
: [
"January", "February", "March", "April", "May", "June",
"July", "August", "September", "October", "November", "December"
];
const label = `${mNameList[monthVal]} ${yearVal}`;
if (!monthlyPnL[ymKey]) monthlyPnL[ymKey] = { pnl: 0, label: label, count: 0 };
monthlyPnL[ymKey].pnl += val;
monthlyPnL[ymKey].count++;

// Best Year grouping
if (!yearlyPnL[yearVal]) yearlyPnL[yearVal] = { pnl: 0, label: yearVal, count: 0 };
yearlyPnL[yearVal].pnl += val;
yearlyPnL[yearVal].count++;
}

// Best Week grouping (simple ISO week approximation)
try {
const d = new Date(t.date + "T12:00:00");
const dNum = d.getTime();
const oneJan = new Date(d.getFullYear(), 0, 1);
const weekNum = Math.ceil((((dNum - oneJan.getTime()) / 86400000) + oneJan.getDay() + 1) / 7);
const ywKey = `${d.getFullYear()}-W${weekNum}`;

// Week range label approximation
const startOfWeek = new Date(dNum - (d.getDay() - 1) * 86400000);
const endOfWeek = new Date(startOfWeek.getTime() + 6 * 86400000);
const label = `${startOfWeek.toLocaleDateString(currentLang === 'ru' ? 'ru' : 'en', {month: 'short', day: 'numeric'})} - ${endOfWeek.getDate()}`;

if (!weeklyPnL[ywKey]) weeklyPnL[ywKey] = { pnl: 0, label: label, count: 0 };
weeklyPnL[ywKey].pnl += val;
weeklyPnL[ywKey].count++;
} catch(e) {}
}

// Best Session grouping
const session = t.session || "";
let mappedSession = "Morning (6AM-12PM)";
if (session.toLowerCase().includes("london") || session.toLowerCase().includes("afternoon")) {
mappedSession = "Afternoon (12PM-6PM)";
} else if (session.toLowerCase().includes("ny") || session.toLowerCase().includes("evening")) {
mappedSession = "Evening (6PM-12AM)";
} else if (session.toLowerCase().includes("asia") || session.toLowerCase().includes("night")) {
mappedSession = "Night (12AM-6AM)";
}
sessionPnL[mappedSession] += val;
sessionCounts[mappedSession]++;
});

const totalTrades = filteredTrades.length;
const winrate = totalTrades > 0 ? (winsCount / totalTrades) * 100 : 0;
const profitFactor = grossLoss > 0 ? (grossProfit / grossLoss).toFixed(2) : grossProfit > 0 ? "999.00" : "0.00";
const expectancy = totalTrades > 0 ? netPnl / totalTrades : 0;
if (smallestWinVal === Infinity) smallestWinVal = 0;

// Sharpe Ratio Calculation
let stdDev = 0;
const avgPnl = totalTrades > 0 ? netPnl / totalTrades : 0;
if (totalTrades > 1) {
let sumSq = 0;
filteredTrades.forEach(t => sumSq += Math.pow((parseFloat(t.pnl) || 0) - avgPnl, 2));
stdDev = Math.sqrt(sumSq / (totalTrades - 1)) || 1;
}
const sharpe = stdDev > 0 ? (avgPnl / stdDev).toFixed(2) : "0.00";

// Update UI Core Cards
const pnlClass = netPnl > 0 ? "green" : netPnl < 0 ? "red" : "gray";
const pfSub = parseFloat(profitFactor) >= 2.0 ? "Perfect" : parseFloat(profitFactor) >= 1.0 ? "Good" : "Poor";

const totalPnlEl = document.getElementById("statsTotalPnl");
if (totalPnlEl) {
totalPnlEl.className = `card-value mono-font ${pnlClass}`;
totalPnlEl.textContent = formatCurrency(netPnl, true);
}
const totalPnlSubEl = document.getElementById("statsTotalPnlSub");
if (totalPnlSubEl) {
totalPnlSubEl.textContent = netPnl > 0 ? "Profit" : netPnl < 0 ? "Loss" : "No Trades";
totalPnlSubEl.style.color = netPnl > 0 ? "#10b981" : netPnl < 0 ? "#ef4444" : "var(--text-muted)";
totalPnlSubEl.style.background = netPnl > 0 ? "rgba(16, 185, 129, 0.08)" : netPnl < 0 ? "rgba(239, 68, 68, 0.08)" : "rgba(255, 255, 255, 0.03)";
}

const winRateEl = document.getElementById("statsWinRate");
if (winRateEl) winRateEl.textContent = `${winrate.toFixed(1)}%`;
const winRateSubEl = document.getElementById("statsWinRateSub");
if (winRateSubEl) winRateSubEl.textContent = `${winsCount}W / ${lossesCount}L`;

const tradesCountEl = document.getElementById("statsTradesCount");
if (tradesCountEl) tradesCountEl.textContent = totalTrades;
const tradesCountSubEl = document.getElementById("statsTradesCountSub");
if (tradesCountSubEl) tradesCountSubEl.textContent = `${totalTrades} closed`;

const avgWinEl = document.getElementById("statsAvgWinVal");
if (avgWinEl) avgWinEl.textContent = formatCurrency(winsCount > 0 ? grossProfit / winsCount : 0);
const avgLossEl = document.getElementById("statsAvgLossVal");
if (avgLossEl) avgLossEl.textContent = formatCurrency(lossesCount > 0 ? -grossLoss / lossesCount : 0);

const pfValEl = document.getElementById("statsProfitFactorVal");
if (pfValEl) pfValEl.textContent = profitFactor;
const pfSubEl = document.getElementById("statsProfitFactorSub");
if (pfSubEl) {
pfSubEl.textContent = pfSub;
pfSubEl.style.color = pfSub === "Perfect" ? "#a855f7" : pfSub === "Good" ? "#10b981" : "#ef4444";
pfSubEl.style.background = pfSub === "Perfect" ? "rgba(168, 85, 247, 0.1)" : pfSub === "Good" ? "rgba(16, 185, 129, 0.08)" : "rgba(239, 68, 68, 0.08)";
}

// Update UI Advanced Cards
const expectancyEl = document.getElementById("statsExpectancy");
if (expectancyEl) {
const expectancyClass = expectancy > 0 ? "green" : expectancy < 0 ? "red" : "gray";
expectancyEl.className = `card-value mono-font ${expectancyClass}`;
expectancyEl.textContent = formatCurrency(expectancy, true);
}

const sharpeEl = document.getElementById("statsSharpe");
pXPBar.style.background = `linear-gradient(90deg, #3b82f6, ${info.color})`;
}
}
